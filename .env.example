# ===========================================
# 服务器配置
# ===========================================
SERVER_IP=127.0.0.1
SERVER_PORT=8000

# 数据库配置
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/medicals

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SERVER_EXE=B:\.path\Redis-7.4.2-Windows-x64-msys2-with-Service\redis-server.exe
REDIS_STARTUP_TIMEOUT_S=5

# JWT & 安全配置
# JWT 密钥 (必须修改为随机字符串)
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Token 过期时间配置
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Bcrypt 加密轮数
BCRYPT_ROUNDS=12

# 会话管理
MAX_CONCURRENT_SESSIONS=3

# ===========================================
# 密码策略
# ===========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# 弱密码黑名单 (逗号分隔)
WEAK_PASSWORDS=123456,password,qwerty,admin,letmein,12345678

# ===========================================
# 邮件配置 (用于登录提醒)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
EMAIL_FROM=notifications@example.com
EMAIL_FROM_NAME=医疗数据分析系统

# ===========================================
# 文件上传配置
# ===========================================
USER_STATIC_FILE_PATH=B:\3_after_end\medicalBs\static\user
MAX_UPLOAD_SIZE=10485760

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
